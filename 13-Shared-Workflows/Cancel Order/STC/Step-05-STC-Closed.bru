meta {
  name: Step-05-STC-Closed
  type: http
  seq: 5
}

post {
  url: {{demo-mob-dev}}/serviceInstallationManagement/v1/notification/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "eventId": "Event-{{orderId}}",
    "eventTime": "{{eventTime}}",
    "eventType": "serviceOrderStateChangeNotification",
    "event": {
      "serviceOrder": {
        "funcId": "UPDATE_ORDER",
        "externalId": "{{stcInstallationId}}",
        "lineItemIdentifier": "",
        "lineItemStatus": "",
        "description": "Success",
        "orderStatus": "Closed",
        "comments": "",
        "providerStatus": "Closed",
        "providerMilestone": "",
        "providerComments": "",
        "orderTransactionNo": "{{stcInstallationId}}",
        "serviceAccNum": "{{customerSAN}}"
      }
    }
  }
}

script:pre-request {
  bru.setVar('eventTime', new Date().toISOString());
  bru.setVar('eventDate', new Date().toISOString());
}

settings {
  encodeUrl: true
  timeout: 0
}

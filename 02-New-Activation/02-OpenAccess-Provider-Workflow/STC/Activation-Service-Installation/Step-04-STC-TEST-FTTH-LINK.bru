meta {
  name: STC-TEST_FTTH_LINK
  type: http
  seq: 4
}

post {
  url: {{demo-mob-dev}}/serviceInstallationManagement/v1/notification/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "eventId": "Event-{{orderId}}",
    "eventTime": "{{eventDate}}",
    "eventType": "serviceOrderStateChangeNotification",
    "event": {
      "serviceOrder": {
        "funcId": "STC_CPE_UPDATE",
        "externalId": "{{stcInstallationId}}",
        "lineItemIdentifier": "",
        "lineItemStatus": "",
        "description": "",
        "orderStatus": "",
        "comments": "",
        "providerStatus": "ORDERED",
        "providerMilestone": "TEST_FTTH_LINK",
        "providerComments": "",
        "orderTransactionNo": "{{stcInstallationId}}",
        "serviceAccNum": "MY55978025", //need to ask
        "devices": [
          {
            "integrationId": "1083097",
            "newSerialNumber": "TK3B119000556"
          }
        ]
      }
    }
  }
}

script:pre-request {
  bru.setVar('eventDate', new Date().toISOString());
}

settings {
  encodeUrl: true
  timeout: 0
}

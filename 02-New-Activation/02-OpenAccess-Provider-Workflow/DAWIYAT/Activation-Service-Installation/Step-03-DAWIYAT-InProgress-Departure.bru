meta {
  name: Dawiyat-InProgress-Departure
  type: http
  seq: 4
}

post {
  url: {{demo-mob-dev}}/serviceInstallationManagement/v1/notification/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "eventId": "Event-{{orderId}}",
    "eventTime": "{{eventTime}}",
    "eventType": "serviceOrderStateChangeNotification",
    "event": {
      "serviceOrder": {
        "funcId": "UPDATE_ORDER",
        "externalId": "{{dawiyatInstallationId}}",
        "lineItemIdentifier": "",
        "lineItemStatus": "",
        "description": "Broadband Service Install",
        "orderStatus": "InProgress-Departure",
        "comments": "",
        "providerStatus": "InProgress-Departure",
        "providerMilestone": "InProgress-Departure",
        "providerComments": "Broadband Service Install",
      "orderTransactionNo" : "1-269535257084", //need to ask
      "serviceAccNum" : "" //need to ask
      }
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

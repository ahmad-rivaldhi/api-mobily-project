meta {
  name: Step-01 ME - 1000 OK
  type: http
  seq: 1
}

post {
  url: {{demo-mob-dev}}/workForceManagement/v1/notification/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "eventId": "Event-{{orderId}}",
    "eventTime": "{{eventDate}}",
    "eventType": "workOrderStateChangeNotification",
    "event": {
      "workOrder": {
        "id": "{{workOrderIdMe}}",
        "externalId": "{{orderId}}",
        "state": "OK",
        "code": "1000"
      }
    }
  }
}

script:pre-request {
  const orderId = bru.getVar('orderId');
  const ts = new Date().toISOString().replace(/[-:T.Z]/g, '').slice(0, 16);
  if (orderId && !bru.getVar('workOrderIdMe')) {
    bru.setVar('workOrderIdMe', '2-me-' + orderId + ts);
  }
  bru.setVar('eventTime', new Date().toISOString());
  bru.setVar('eventDate', new Date().toISOString());
}

settings {
  encodeUrl: true
  timeout: 0
}

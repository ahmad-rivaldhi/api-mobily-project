meta {
  name: Trip Started - notification
  type: http
  seq: 10
}

post {
  url: {{demo-mob-dev}}/workForceManagement/v1/notification/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "eventId": "Event-{{orderId}}",
    "eventTime": "{{eventDate}}",
    "eventType": "workOrderStateChangeNotification",
    "event": {
      "workOrder": {
        "id": "{{workOrderIdMe}}",
        "externalId": "{{orderId}}",
        "state": "TRIP STARTED",
        "partition": "VIRTUALVENDOR_TripStarted",
        "region": "CENTER-CENTER_1_TripStarted",
        "vendorName": "VIRTUALVENDOR_TripStarted",
        "engineerId": "EngTripStarted",
        "engineerName": "MOTTEST03",
        "engineerPhone": "+966-56-0019905",
        "timestamp": "{{eventDate}}"
      }
    }
  }
}

script:pre-request {
  bru.setVar('eventTime', new Date().toISOString());
  bru.setVar('eventDate', new Date().toISOString());
}

settings {
  encodeUrl: true
  timeout: 0
}

meta {
  name: (T2) DOWIYAT - Customer cancelation
  type: http
  seq: 2
}

post {
  url: {{demo-mob-dev}}/serviceInstallationManagement/v1/notification/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "eventId": "Event-{{orderId}}",
    "eventTime": "{{eventDate}}",
    "eventType": "serviceOrderStateChangeNotification",
    "event": {
      "serviceOrder": {
        "funcId": "DOWIYAT_ORDER_UPDATE",
        "externalId": "DAW20260310072911",
        "lineItemIdentifier": "", //not present so blank
        "lineItemStatus": "", //not present so blank
        "description": "",
        "orderStatus": "",
        "comments": "",
        "providerStatus": "Pending",
        "providerMilestone": "Pending",
        "providerComments": "Broadband Service Install - Comments",
        "orderTransactionNo" : "", //Need to ask
        "serviceAccNum" : "", //need to ask
        "reasonCode": "",
        "reasonText": "Customer cancelation"
      }
    }
  }
}

vars:pre-request {
  itcOrderId: 1-260306144528
}

script:pre-request {
  bru.setVar('eventTime', new Date().toISOString());
  bru.setVar('eventDate', new Date().toISOString());
}

settings {
  encodeUrl: true
  timeout: 0
}
